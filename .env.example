# Copy to .env and fill in. All values are optional — the pipeline runs offline
# with deterministic fallbacks when these are unset.

# Google Gemini API key (free tier) for the LLM root-cause summarizer.
# Get one free at https://aistudio.google.com/apikey
# If unset, the summarizer falls back to a deterministic template (no network call).
GEMINI_API_KEY=

# Model used for summaries (free-tier Gemini default).
LOGANALYSIS_LLM_MODEL=gemini-2.5-flash

# HITL review trigger: alerts with confidence below this go to a human (PRD §05).
LOGANALYSIS_CONFIDENCE_THRESHOLD=0.65
